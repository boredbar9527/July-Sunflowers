{
  "name": "july-sunflowers",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "catalog": "node scripts/build-catalog.mjs",
    "dev": "npm run catalog && vite",
    "admin": "node scripts/admin-server.mjs --open",
    "start": "concurrently -n web,admin -c green,cyan \"npm run dev\" \"npm run admin\"",
    "build": "npm run catalog && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "vite": "^7.2.0"
  }
}
